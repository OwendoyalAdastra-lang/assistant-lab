#!/bin/bash
# Assistant Lab — double-click launcher for mom's Mac
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
APP_BUNDLE="$(cd "$SCRIPT_DIR/../.." && pwd)"
INSTALL_DIR="$(dirname "$APP_BUNDLE")"
LOG="$INSTALL_DIR/assistant-lab-last-run.log"

log() { echo "[$(date '+%H:%M:%S')] $*" >> "$LOG"; }

alert() {
  /usr/bin/osascript -e "display alert \"Assistant Lab\" message \"$1\"" 2>/dev/null || true
}

log "=== Assistant Lab start ==="
log "Install dir: $INSTALL_DIR"
cd "$INSTALL_DIR" || { alert "Cannot open game folder."; exit 1; }

PY=""
for candidate in \
  /Library/Frameworks/Python.framework/Versions/3.14/bin/python3 \
  /Library/Frameworks/Python.framework/Versions/3.12/bin/python3 \
  /Library/Frameworks/Python.framework/Versions/3.13/bin/python3 \
  /usr/local/bin/python3 \
  /opt/homebrew/bin/python3 \
  python3; do
  if [[ -x "$candidate" ]] 2>/dev/null || command -v "$candidate" >/dev/null 2>&1; then
    if "$candidate" -c "import sys" >> "$LOG" 2>&1; then
      PY="$candidate"
      break
    fi
  fi
done

if [[ -z "$PY" ]]; then
  log "ERROR: Python not found"
  alert "Python not found. Install from python.org/downloads then try again."
  exit 1
fi
log "Python: $PY"

if ! "$PY" -c "import pygame" >> "$LOG" 2>&1; then
  log "Installing pygame-ce..."
  if ! "$PY" -m pip install --user pygame-ce >> "$LOG" 2>&1; then
    "$PY" -m pip install pygame-ce >> "$LOG" 2>&1 || {
      log "ERROR: pygame install failed"
      alert "Could not install pygame. Open assistant-lab-last-run.log for details."
      exit 1
    }
  fi
fi

SERVER_IP=""
if [[ -f "$INSTALL_DIR/server-ip.txt" ]]; then
  SERVER_IP=$(grep -v '^#' "$INSTALL_DIR/server-ip.txt" | grep -v '^[[:space:]]*$' | head -1 | tr -d '[:space:]')
fi
log "Server IP from file: ${SERVER_IP:-none}"

export ASSISTANT_LAB_CHAT_PORT=9876
if [[ -n "$SERVER_IP" && "$SERVER_IP" != "127.0.0.1" ]]; then
  export ASSISTANT_LAB_CHAT_HOST="$SERVER_IP"
fi

GAME="$INSTALL_DIR/build_your_own_smart_assistant_pygame.py"
if [[ ! -f "$GAME" ]]; then
  log "ERROR: Game file missing at $GAME"
  alert "Game files missing. Unzip the full Assistant-Lab-Mac folder — do not move only the .app icon."
  exit 1
fi

log "Launching game..."
cd "$INSTALL_DIR"
"$PY" "$GAME" >> "$LOG" 2>&1
EXIT=$?
log "Game exited with code $EXIT"

if [[ $EXIT -ne 0 ]]; then
  alert "Game closed with an error. Open assistant-lab-last-run.log in the Assistant-Lab-Mac folder."
fi
exit "$EXIT"